{
  "info": {
    "name": "aeroenix API",
    "description": "Matches `routes/api.php` (prefix `/api`) plus `routes/web.php` root and Laravel `/up` health. Mutations (POST/PUT/PATCH/DELETE except notifications mark-read) require `not_viewer` middleware — use a non-viewer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "root_url", "value": "http://127.0.0.1:8000" },
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token", "value": "" },
    { "key": "project_id", "value": "1" },
    { "key": "service_id", "value": "1" },
    { "key": "page_id", "value": "1" },
    { "key": "message_id", "value": "1" },
    { "key": "ticket_id", "value": "1" },
    { "key": "user_id", "value": "1" }
  ],
  "item": [
    {
      "name": "App",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{root_url}}/"
          }
        },
        {
          "name": "Health (up)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{root_url}}/up"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
