              "raw": "{\n  \"title\": \"Updated title\",\n  \"client\": \"Client Co\",\n  \"category\": \"Web Application\",\n  \"description\": \"Updated description\",\n  \"status\": \"draft\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/projects/{{project_id}}"
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
